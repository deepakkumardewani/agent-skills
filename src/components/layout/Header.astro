---
const navItems = [
  { href: '/docs', label: 'Docs', external: false },
  { href: '/about', label: 'About', external: false },
  {
    href: 'https://github.com/addyosmani/agent-skills',
    label: 'GitHub',
    external: true,
  },
] as const;

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-header__brand" href="/">
      <span class="site-header__title">addy-osmani-skills</span>
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <ul class="site-header__nav-list">
        {
          navItems.map((item) => (
            <li>
              <a
                class:list={[
                  'site-header__nav-link',
                  { 'is-active': !item.external && currentPath.startsWith(item.href) },
                ]}
                href={item.href}
                {...(item.external
                  ? { target: '_blank', rel: 'noopener noreferrer' }
                  : {})}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="site-header__actions">
      <button
        type="button"
        class="site-header__search"
        aria-label="Search skills (coming soon)"
        disabled
      >
        <span class="site-header__search-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" />
            <path d="M20 20L16 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </span>
        <span class="site-header__search-label">Search</span>
        <kbd class="site-header__search-kbd" aria-hidden="true">⌘K</kbd>
      </button>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-outline);
    background: color-mix(in srgb, var(--color-bg-default) 92%, transparent);
    backdrop-filter: none;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    width: min(100%, var(--space-container-max));
    margin: 0 auto;
    padding: var(--space-3) var(--space-container-padding);
  }

  .site-header__brand {
    flex-shrink: 0;
    text-decoration: none;
    color: var(--color-fg-default);
  }

  .site-header__brand:focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus);
    border-radius: var(--radius-sm);
  }

  .site-header__title {
    font-size: var(--text-label-md-size);
    font-weight: var(--text-label-md-weight);
    line-height: var(--text-label-md-line-height);
    letter-spacing: var(--text-label-md-letter-spacing);
  }

  .site-header__nav {
    flex: 1;
    min-width: 0;
  }

  .site-header__nav-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-1);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-header__nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0 var(--space-3);
    border-radius: var(--radius-default);
    font-size: var(--text-label-md-size);
    font-weight: var(--text-label-md-weight);
    line-height: var(--text-label-md-line-height);
    color: var(--color-fg-muted);
    text-decoration: none;
    transition: background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }

  .site-header__nav-link:hover {
    background: var(--color-surface-elevated);
    color: var(--color-fg-default);
  }

  .site-header__nav-link:focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus);
  }

  .site-header__nav-link.is-active {
    background: var(--color-primary-subtle);
    color: var(--color-on-primary-subtle);
  }

  .site-header__actions {
    flex-shrink: 0;
  }

  .site-header__search {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    min-height: 40px;
    padding: 0 var(--space-3);
    border: 1px solid var(--color-outline);
    border-radius: var(--radius-default);
    background: var(--color-surface);
    color: var(--color-fg-muted);
    font-family: inherit;
    font-size: var(--text-label-md-size);
    font-weight: var(--text-label-md-weight);
    cursor: not-allowed;
    opacity: 0.72;
  }

  .site-header__search-icon {
    display: inline-flex;
    color: var(--color-fg-subtle);
  }

  .site-header__search-kbd {
    display: none;
    padding: 0 var(--space-1);
    border: 1px solid var(--color-outline);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: var(--text-code-sm-size);
    line-height: 1.4;
    background: var(--color-code-bg);
  }

  .site-header__search-label {
    display: none;
  }

  @media (min-width: 640px) {
    .site-header__search-label,
    .site-header__search-kbd {
      display: inline;
    }
  }

  @media (min-width: 960px) {
    .site-header__inner {
      padding-inline: var(--space-page-gutter);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header__nav-link {
      transition: none;
    }
  }
</style>
