---
import { isDocsRoute, MOBILE_NAV_MEDIA_QUERY } from '../../lib/mobile-nav';
import { isNavActive, NAV_ITEMS } from '../../lib/nav';
import { addy } from '../../lib/site';
import SearchTrigger from '../search/SearchTrigger.astro';
import MobileNav from './MobileNav';
import SiteNavMenu from './SiteNavMenu';
import ThemeToggle from './ThemeToggle.astro';

const showMobileNav = isDocsRoute(Astro.url.pathname);
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header__inner">
    <div class="site-header__start">
      {
        showMobileNav ? (
          <MobileNav client:media={MOBILE_NAV_MEDIA_QUERY} />
        ) : (
          <SiteNavMenu client:media={MOBILE_NAV_MEDIA_QUERY} />
        )
      }
      <a class="site-header__brand" href="/">
        <span class="site-header__mark" aria-hidden="true"></span>
        <span class="site-header__wordmark">
          <span class="site-header__wordmark-base">addy-osmani:</span><span
            class="site-header__wordmark-accent">agent-skills</span
          >
        </span>
      </a>
    </div>

    <nav class="site-header__nav" aria-label="Primary">
      <ul class="site-header__nav-list">
        {
          NAV_ITEMS.map((item) => (
            <li>
              <a
                class:list={[
                  'site-header__nav-link',
                  { 'is-active': isNavActive(currentPath, item.href) },
                ]}
                href={item.href}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="site-header__actions">
      <SearchTrigger />
      <a
        class="site-header__github"
        href={addy.repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub repository"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M12 2C6.48 2 2 6.58 2 12.26c0 4.52 2.87 8.35 6.84 9.7.5.1.68-.22.68-.48 0-.24-.01-.87-.01-1.7-2.78.62-3.37-1.36-3.37-1.36-.45-1.18-1.12-1.5-1.12-1.5-.92-.64.07-.63.07-.63 1.02.07 1.55 1.07 1.55 1.07.9 1.57 2.36 1.12 2.94.86.09-.67.35-1.12.63-1.38-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.27 2.75 1.03A9.2 9.2 0 0 1 12 6.84c.85 0 1.71.12 2.51.35 1.91-1.3 2.75-1.03 2.75-1.03.55 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.07.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.59.69.49A10.03 10.03 0 0 0 22 12.26C22 6.58 17.52 2 12 2Z"
            fill="currentColor"></path>
        </svg>
      </a>
      <ThemeToggle />
    </div>
  </div>
  <div id="search-dialog-root"></div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-outline);
    background: color-mix(in srgb, var(--color-bg-default) 92%, transparent);
    backdrop-filter: none;
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-4);
    width: min(100%, var(--space-container-max));
    margin: 0 auto;
    padding: var(--space-3) var(--space-4);
  }

  .site-header__start {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    min-width: 0;
    grid-column: 1;
    grid-row: 1;
    justify-self: start;
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 1;
    min-width: 0;
    text-decoration: none;
    color: var(--color-fg-default);
  }

  .site-header__brand:focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus);
    border-radius: var(--radius-sm);
  }

  .site-header__mark {
    flex-shrink: 0;
    width: var(--space-2);
    height: var(--space-5);
    border-radius: var(--radius-sm);
    background: linear-gradient(
      180deg,
      var(--color-accent) 0%,
      color-mix(in srgb, var(--color-accent) 55%, var(--color-fg-muted)) 100%
    );
  }

  .site-header__wordmark {
    display: inline-flex;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: var(--text-label-md-size);
    font-weight: var(--text-label-md-weight);
    line-height: var(--text-label-md-line-height);
    letter-spacing: var(--text-label-md-letter-spacing);
  }

  .site-header__wordmark-base {
    color: var(--color-fg-default);
  }

  .site-header__wordmark-accent {
    color: var(--color-link);
    font-weight: 600;
  }

  @media (max-width: 959px) {
    .site-header__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-2);
    }

    .site-header__start {
      flex: 1 1 auto;
      min-width: 0;
      grid-column: unset;
      grid-row: unset;
    }

    .site-header__nav {
      display: none;
    }

    .site-header__actions {
      flex-shrink: 0;
      grid-column: unset;
      grid-row: unset;
    }
  }

  @media (max-width: 479px) {
    .site-header__wordmark-base {
      display: none;
    }
  }

  .site-header__nav {
    grid-column: 2;
    grid-row: 1;
    justify-self: center;
    min-width: 0;
  }

  .site-header__nav-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-1);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-header__nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0 var(--space-3);
    border-radius: var(--radius-default);
    font-size: var(--text-label-md-size);
    font-weight: var(--text-label-md-weight);
    line-height: var(--text-label-md-line-height);
    color: var(--color-fg-muted);
    text-decoration: none;
    transition: background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }

  .site-header__nav-link:hover {
    background: var(--color-surface-elevated);
    color: var(--color-fg-default);
  }

  .site-header__nav-link:focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus);
  }

  .site-header__nav-link.is-active {
    background: var(--color-primary-subtle);
    color: var(--color-on-primary-subtle);
  }

  .site-header__actions {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: var(--space-2);
    grid-column: 3;
    grid-row: 1;
    justify-self: end;
  }

  .site-header__github,
  .site-header__actions :global(.theme-toggle),
  .site-header__start :global(.mobile-nav__trigger) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    min-height: 40px;
    padding: 0;
    border: none;
    border-radius: var(--radius-default);
    background: transparent;
    color: var(--color-fg-muted);
    font-family: inherit;
    text-decoration: none;
    cursor: pointer;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .site-header__github:hover,
  .site-header__actions :global(.theme-toggle:hover),
  .site-header__start :global(.mobile-nav__trigger:hover) {
    color: var(--color-fg-default);
  }

  .site-header__github:focus-visible,
  .site-header__actions :global(.theme-toggle:focus-visible),
  .site-header__start :global(.mobile-nav__trigger:focus-visible) {
    outline: none;
    box-shadow: var(--shadow-focus);
  }

  .site-header__github svg,
  .site-header__start :global(.mobile-nav__trigger svg) {
    display: inline-flex;
    color: inherit;
  }

  .site-header__actions :global(.theme-toggle__icon) {
    color: inherit;
  }

  .site-header__actions
    :global(.theme-toggle:not([data-active-theme='dark']) > .theme-toggle__icon--dark) {
    display: none;
  }

  .site-header__actions
    :global(.theme-toggle[data-active-theme='dark'] > .theme-toggle__icon--light) {
    display: none;
  }

  @media (min-width: 960px) {
    .site-header__inner {
      padding-inline: var(--space-page-gutter);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header__nav-link,
    .site-header__github,
    .site-header__actions :global(.theme-toggle),
    .site-header__start :global(.mobile-nav__trigger) {
      transition: none;
    }
  }
</style>
