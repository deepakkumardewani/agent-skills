---
import { MOBILE_NAV_MEDIA_QUERY } from '../../lib/mobile-nav';
import MobileNav from './MobileNav';
import ThemeToggle from './ThemeToggle.astro';

const showMobileNav = Astro.url.pathname === '/docs' || Astro.url.pathname.startsWith('/docs/');

const navItems = [
  { href: '/docs', label: 'Docs', external: false },
  { href: '/about', label: 'About', external: false },
  {
    href: 'https://github.com/addyosmani/agent-skills',
    label: 'GitHub',
    external: true,
  },
] as const;

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header__inner">
    <div class="site-header__start">
      {showMobileNav && <MobileNav client:media={MOBILE_NAV_MEDIA_QUERY} />}
      <a class="site-header__brand" href="/">
        <span class="site-header__title">addy-osmani-skills</span>
      </a>
    </div>

    <nav class="site-header__nav" aria-label="Primary">
      <ul class="site-header__nav-list">
        {
          navItems.map((item) => (
            <li>
              <a
                class:list={[
                  'site-header__nav-link',
                  { 'is-active': !item.external && currentPath.startsWith(item.href) },
                ]}
                href={item.href}
                {...(item.external
                  ? { target: '_blank', rel: 'noopener noreferrer' }
                  : {})}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="site-header__actions">
      <button
        id="site-search-trigger"
        type="button"
        class="site-header__search"
        aria-label="Search skills"
        aria-keyshortcuts="Control+K Meta+K"
      >
        <span class="site-header__search-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2" />
            <path d="M20 20L16 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </span>
        <span class="site-header__search-label">Search</span>
        <kbd class="site-header__search-kbd" aria-hidden="true">⌘K</kbd>
      </button>
      <ThemeToggle />
    </div>
  </div>
  <div id="search-dialog-root"></div>
</header>

<script>
  import { setupSearchLauncher } from '../../lib/search-boot';
  setupSearchLauncher();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-outline);
    background: color-mix(in srgb, var(--color-bg-default) 92%, transparent);
    backdrop-filter: none;
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-4);
    width: min(100%, var(--space-container-max));
    margin: 0 auto;
    padding: var(--space-3) var(--space-4);
  }

  .site-header__start {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    min-width: 0;
    grid-column: 1;
    grid-row: 1;
    justify-self: start;
  }

  .site-header__brand {
    flex-shrink: 1;
    min-width: 0;
    text-decoration: none;
    color: var(--color-fg-default);
  }

  .site-header__brand:focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus);
    border-radius: var(--radius-sm);
  }

  .site-header__title {
    font-size: var(--text-label-md-size);
    font-weight: var(--text-label-md-weight);
    line-height: var(--text-label-md-line-height);
    letter-spacing: var(--text-label-md-letter-spacing);
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 959px) {
    html.has-mobile-skills-nav .site-header__nav {
      display: none;
    }
  }

  @media (max-width: 479px) {
    .site-header__nav-link[href*='github.com'] {
      display: none;
    }
  }

  .site-header__nav {
    grid-column: 2;
    grid-row: 1;
    justify-self: center;
    min-width: 0;
  }

  .site-header__nav-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-1);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-header__nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0 var(--space-3);
    border-radius: var(--radius-default);
    font-size: var(--text-label-md-size);
    font-weight: var(--text-label-md-weight);
    line-height: var(--text-label-md-line-height);
    color: var(--color-fg-muted);
    text-decoration: none;
    transition: background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }

  .site-header__nav-link:hover {
    background: var(--color-surface-elevated);
    color: var(--color-fg-default);
  }

  .site-header__nav-link:focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus);
  }

  .site-header__nav-link.is-active {
    background: var(--color-primary-subtle);
    color: var(--color-on-primary-subtle);
  }

  .site-header__actions {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: var(--space-2);
    grid-column: 3;
    grid-row: 1;
    justify-self: end;
  }

  .site-header__search {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    min-width: 40px;
    min-height: 40px;
    padding: 0 var(--space-2);
    border: 1px solid var(--color-outline);
    border-radius: var(--radius-default);
    background: var(--color-surface);
    color: var(--color-fg-muted);
    font-family: inherit;
    cursor: pointer;
    transition:
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }

  .site-header__actions :global(.theme-toggle),
  .site-header__start :global(.mobile-nav__trigger) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    min-height: 40px;
    padding: 0;
    border: none;
    border-radius: var(--radius-default);
    background: transparent;
    color: var(--color-fg-muted);
    font-family: inherit;
    cursor: pointer;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .site-header__search-label,
  .site-header__search-kbd {
    display: none;
  }

  .site-header__search:hover {
    border-color: var(--color-outline-strong);
    background: var(--color-surface-elevated);
    color: var(--color-fg-default);
  }

  .site-header__actions :global(.theme-toggle:hover),
  .site-header__start :global(.mobile-nav__trigger:hover) {
    color: var(--color-fg-default);
  }

  .site-header__search:focus-visible,
  .site-header__actions :global(.theme-toggle:focus-visible),
  .site-header__start :global(.mobile-nav__trigger:focus-visible) {
    outline: none;
    box-shadow: var(--shadow-focus);
  }

  .site-header__search-icon,
  .site-header__start :global(.mobile-nav__trigger svg) {
    display: inline-flex;
    color: inherit;
  }

  .site-header__actions :global(.theme-toggle__icon) {
    color: inherit;
  }

  /* Override legacy bundle rule that forced display on all theme icons */
  .site-header__actions
    :global(.theme-toggle:not([data-active-theme='dark']) > .theme-toggle__icon--dark) {
    display: none;
  }

  .site-header__actions
    :global(.theme-toggle[data-active-theme='dark'] > .theme-toggle__icon--light) {
    display: none;
  }

  @media (min-width: 960px) {
    .site-header__inner {
      padding-inline: var(--space-page-gutter);
    }

    .site-header__search {
      padding-inline: var(--space-3);
      font-size: var(--text-label-md-size);
      font-weight: var(--text-label-md-weight);
      line-height: var(--text-label-md-line-height);
    }

    .site-header__search-label,
    .site-header__search-kbd {
      display: inline;
    }

    .site-header__search-kbd {
      padding: 0 var(--space-1);
      border: 1px solid var(--color-outline);
      border-radius: var(--radius-sm);
      font-family: var(--font-mono);
      font-size: var(--text-code-sm-size);
      line-height: 1.4;
      background: var(--color-code-bg);
      color: var(--color-fg-subtle);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header__nav-link,
    .site-header__search,
    .site-header__actions :global(.theme-toggle),
    .site-header__start :global(.mobile-nav__trigger) {
      transition: none;
    }
  }
</style>
