---
import type { Skill } from '../../data/skills-data';
import { formatSkillDisplayName } from '../../lib/skills';

interface Props {
  skill: Skill;
}

const { skill } = Astro.props;
const displayName = formatSkillDisplayName(skill.name);
const trigger = skill.triggers[0];
---

<header class="skill-header-card">
  <h1 class="skill-header-card__title">{displayName}</h1>
  <p class="skill-header-card__description">{skill.description}</p>
  {
    trigger ? (
      <p class="skill-header-card__trigger">
        Trigger: <code>{trigger}</code>
      </p>
    ) : (
      <p class="skill-header-card__trigger">Activates automatically</p>
    )
  }
</header>

<style>
  .skill-header-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-4);
    border: 1px solid var(--color-outline);
    border-radius: var(--radius-xl);
    background: var(--color-surface);
    box-shadow: var(--shadow-md);
  }

  @media (min-width: 640px) {
    .skill-header-card {
      padding: var(--space-8);
    }
  }

  .skill-header-card__title {
    font-size: var(--text-headline-lg-size);
    font-weight: var(--text-headline-lg-weight);
    line-height: var(--text-headline-lg-line-height);
    letter-spacing: var(--text-headline-lg-letter-spacing);
    color: var(--color-fg-default);
  }

  .skill-header-card__description {
    font-size: var(--text-body-lg-size);
    font-weight: var(--text-body-lg-weight);
    line-height: var(--text-body-lg-line-height);
    color: var(--color-fg-muted);
  }

  .skill-header-card__trigger {
    font-size: var(--text-body-sm-size);
    font-weight: var(--text-body-sm-weight);
    line-height: var(--text-body-sm-line-height);
    color: var(--color-fg-muted);
  }

  .skill-header-card__trigger code {
    font-family: var(--font-mono);
    font-size: var(--text-code-sm-size);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    background: var(--color-surface-muted);
    color: var(--color-fg-default);
  }
</style>
