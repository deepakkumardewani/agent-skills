---
import { ADLC_COMMAND_ROWS } from '../../lib/adlc-cycle';
---

<section class="commands-table" aria-labelledby="commands-table-title" role="region">
  <h2 id="commands-table-title" class="commands-table__title">Commands</h2>
  <p class="commands-table__lede">
    Seven slash commands map to the development lifecycle. Each one activates the right skills
    automatically.
  </p>

  <div class="commands-table__wrap">
    <table class="commands-table__table">
      <caption class="commands-table__caption">
        What you are doing, the slash command, and the key principle from the README
      </caption>
      <thead>
        <tr>
          <th scope="col">What you're doing</th>
          <th scope="col">Command</th>
          <th scope="col">Key principle</th>
        </tr>
      </thead>
      <tbody>
        {
          ADLC_COMMAND_ROWS.map((row) => (
            <tr>
              <td>{row.task}</td>
              <td>
                <code>{row.command}</code>
              </td>
              <td>{row.principle}</td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</section>

<style>
  .commands-table {
    width: 100%;
  }

  .commands-table__title {
    font-size: var(--text-headline-md-size);
    font-weight: var(--text-headline-md-weight);
    line-height: var(--text-headline-md-line-height);
    letter-spacing: var(--text-headline-md-letter-spacing);
    text-align: left;
  }

  .commands-table__lede {
    margin-top: var(--space-4);
    max-width: var(--space-prose-max);
    font-size: var(--text-body-md-size);
    line-height: var(--text-body-md-line-height);
    color: var(--color-fg-muted);
    text-align: left;
  }

  .commands-table__wrap {
    margin-top: var(--space-8);
    overflow-x: auto;
    border: 1px solid var(--color-outline);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    box-shadow: var(--shadow-xs);
  }

  .commands-table__caption {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .commands-table__table {
    width: 100%;
    min-width: 36rem;
    border-collapse: collapse;
    font-size: var(--text-body-sm-size);
    line-height: var(--text-body-sm-line-height);
  }

  .commands-table__table th,
  .commands-table__table td {
    padding: var(--space-4) var(--space-5);
    text-align: left;
    vertical-align: top;
    border-bottom: 1px solid var(--color-outline);
  }

  .commands-table__table thead th {
    font-size: var(--text-label-sm-size);
    font-weight: var(--text-label-sm-weight);
    letter-spacing: var(--text-label-sm-letter-spacing);
    text-transform: uppercase;
    color: var(--color-fg-subtle);
    background: var(--color-surface-elevated);
  }

  .commands-table__table tbody tr:last-child td {
    border-bottom: none;
  }

  .commands-table__table tbody tr {
    transition: background-color var(--duration-fast) var(--ease-out);
  }

  .commands-table__table tbody tr:hover td {
    background: var(--color-surface-elevated);
  }

  .commands-table__table tbody td:first-child {
    color: var(--color-fg-default);
    font-weight: 500;
  }

  .commands-table__table code {
    font-family: var(--font-mono);
    font-size: var(--text-code-sm-size);
    color: var(--color-link);
  }

  .commands-table__table tbody td:last-child {
    color: var(--color-fg-muted);
  }

  .commands-table__table tbody td:nth-child(2) {
    width: 9rem;
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: reduce) {
    .commands-table__table tbody tr {
      transition: none;
    }
  }
</style>
