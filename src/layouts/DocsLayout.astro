---
import Sidebar from '../components/layout/Sidebar.astro';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="docs-shell">
    <aside class="docs-shell__sidebar">
      <Sidebar />
    </aside>
    <div class="docs-shell__main">
      <slot />
    </div>
  </div>
</BaseLayout>

<style>
  .docs-shell {
    display: flex;
    flex-direction: column;
    width: min(100%, var(--space-container-max));
    min-height: calc(100vh - var(--space-16));
    margin: 0 auto;
    padding-inline: var(--space-4);
  }

  .docs-shell__sidebar {
    display: none;
  }

  .docs-shell__main {
    flex: 1;
    min-width: 0;
  }

  @media (min-width: 960px) {
    .docs-shell {
      flex-direction: row;
      gap: var(--space-8);
      padding-inline: var(--space-page-gutter);
      min-height: calc(100dvh - var(--layout-header-height));
    }

    .docs-shell__sidebar {
      display: block;
      flex: 0 0 var(--space-sidebar-width);
      width: var(--space-sidebar-width);
      position: fixed;
      top: var(--layout-header-height);
      left: var(--layout-docs-sidebar-left);
      bottom: 0;
      z-index: 10;
      overflow-y: auto;
      overscroll-behavior: contain;
      padding-block: var(--space-8);
      border-right: 1px solid var(--color-outline);
      padding-right: var(--space-4);
      background: var(--color-bg-default);
    }

    .docs-shell__main {
      flex: 1;
      min-width: 0;
      margin-left: calc(var(--space-sidebar-width) + var(--space-8));
      padding-block: 0;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .docs-shell__sidebar {
      scroll-behavior: smooth;
    }
  }
</style>
