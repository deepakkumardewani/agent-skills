{
  "name": "addy-osmani-skills",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "Browsable docs site for Addy Osmani's agent-skills, organized by the ADLC.",
  "author": "Deepak Kumar Dewani",
  "license": "MIT",
  "homepage": "https://addy-osmani-skills.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/deepakkumardewani/agent-skills.git"
  },
  "bugs": "https://github.com/deepakkumardewani/agent-skills/issues",
  "keywords": [
    "agent-skills",
    "astro",
    "documentation",
    "adlc",
    "ai-coding"
  ],
  "packageManager": "bun@1.3.6",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:e2e:ui": "playwright test --ui",
    "sync-skills": "bun run scripts/sync-skills.ts",
    "typecheck": "astro check",
    "check": "biome check . && astro check && vitest run",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/preact": "^5.1.4",
    "@astrojs/vercel": "^10.0.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "astro": "^6.4.2",
    "minisearch": "^7.2.0",
    "preact": "^10.29.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.7",
    "happy-dom": "^20.10.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
